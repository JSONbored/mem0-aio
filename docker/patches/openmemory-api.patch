     except Exception as e:
         logging.warning(f"Failed to get memory client: {e}")
         return None
+
+def refresh_vector_store_if_supported(memory_client):
+    """Refresh backends with eventual-consistency indexes before MCP search."""
+    vector_store = getattr(memory_client, "vector_store", None)
+    collection_name = getattr(vector_store, "collection_name", None)
+    if not collection_name:
+        return
+
+    client = getattr(vector_store, "client", None)
+    indices = getattr(client, "indices", None)
+    refresh = getattr(indices, "refresh", None)
+    if not callable(refresh):
+        return
+
+    try:
+        refresh(index=collection_name)
+    except Exception as e:
+        logging.debug(f"Skipping vector store refresh before search: {e}")

 # Context variables for user_id and client_name
 user_id_var: contextvars.ContextVar[str] = contextvars.ContextVar("user_id")
